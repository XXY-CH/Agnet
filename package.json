{
  "name": "agnet",
  "version": "0.1.0-dev.6",
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "asp-verify": "./asp-verify.mjs",
    "agnet-key": "./agnet-key.mjs",
    "agnet-daemon": "./agnet-daemon.mjs"
  },
  "exports": {
    ".": "./asp-core.mjs",
    "./client": {
      "types": "./agnet-client.d.mts",
      "import": "./agnet-client.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:package": "node scripts/build-package.mjs",
    "prepack": "npm run build:package",
    "test:package": "node --test test/agnet-client.test.mjs test/package-surface.test.mjs",
    "test:platform": "npm run build:package && node --test test/platform-package.test.mjs"
  },
  "optionalDependencies": {
    "@agnet-ai/daemon-darwin-arm64": "0.1.0-dev.6",
    "@agnet-ai/daemon-darwin-x64": "0.1.0-dev.6",
    "@agnet-ai/daemon-linux-arm64": "0.1.0-dev.6",
    "@agnet-ai/daemon-linux-x64": "0.1.0-dev.6"
  },
  "files": [
    "asp-core.mjs",
    "asp-verify.mjs",
    "swarm-output-verification.mjs",
    "agnet-key.mjs",
    "managed-key.mjs",
    "managed-key-store.mjs",
    "secure-input.mjs",
    "secure-input-openat.py",
    "agnet-client.mjs",
    "agnet-client.d.mts",
    "agnet-daemon.mjs",
    "README.md"
  ]
}
